# --- Huge Folders (Token Eaters) ---
node_modules/
.git/
dist/
build/
.next/

# --- Knowledge Base (Lazy Load only via @mention) ---
# This prevents the agent from reading your whole library unless asked.
/Library/**

# --- Media & Binary Files (No value for the LLM) ---
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.pdf
*.mp4
*.zip

# --- Logs & Temp Files ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
